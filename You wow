import { createFileRoute, useNavigate, Link } from "@tanstack/react-router";
import { useState } from "react";
import {
  Package,
  Search,
  ShoppingBag,
  Phone,
  MapPin,
  Globe2,
  AlertCircle,
  Loader2,
} from "lucide-react";
import heroBg from "@/assets/hero-bg.jpg";
import logoAsset from "@/assets/uwow-logo.asset.json";
import { supabase } from "@/integrations/supabase/client";
import { WhatsAppFab } from "@/components/WhatsAppButton";
import promo1 from "@/assets/uwow-promo-1.jpg.asset.json";
import promo2 from "@/assets/uwow-promo-2.jpg.asset.json";
import promo3 from "@/assets/uwow-promo-3.jpg.asset.json";

const PROMO_IMAGES = [promo1.url, promo2.url, promo3.url];

export const Route = createFileRoute("/")({
  head: () => ({
    meta: [
      { title: "يو واو | أطلق العنان لذوقك - تتبع شحنتك" },
      {
        name: "description",
        content:
          "يو واو - شحن وتوصيل من جميع مواقع التسوق العالمية والخليجية إلى جميع مناطق اليمن. تتبع شحنتك الآن.",
      },
      { property: "og:title", content: "يو واو | أطلق العنان لذوقك" },
      {
        property: "og:description",
        content: "شحن وتوصيل من جميع مواقع التسوق العالمية إلى اليمن.",
      },
    ],
    links: [
      {
        rel: "stylesheet",
        href: "https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&display=swap",
      },
    ],
  }),
  component: Index,
});

const SERVICES = [
  { name: "شي إن", tag: "SHEIN", grad: "from-pink-500 to-rose-600" },
  { name: "نون", tag: "noon", grad: "from-amber-400 to-yellow-500" },
  { name: "أمازون", tag: "amazon", grad: "from-orange-500 to-amber-600" },
  { name: "علي إكسبرس", tag: "AliExpress", grad: "from-red-500 to-orange-500" },
];

function Index() {
  const navigate = useNavigate();
  const [tracking, setTracking] = useState("");
  const [error, setError] = useState<string | null>(null);
  const [loading, setLoading] = useState(false);

  async function handleSubmit(e: React.FormEvent) {
    e.preventDefault();
    const id = tracking.trim();
    if (!id) return;
    setError(null);
    setLoading(true);
    const { data, error: dbError } = await supabase
      .from("shipments")
      .select("tracking_number")
      .eq("tracking_number", id)
      .maybeSingle();
    setLoading(false);
    if (dbError) {
      setError("تعذّر الاتصال. حاول مرة أخرى.");
      return;
    }
    if (!data) {
      setError("رقم الشحنة غير موجود. تأكد من الرقم وحاول مرة أخرى.");
      return;
    }
    navigate({ to: "/track/$id", params: { id } });
  }

  return (
    <div className="min-h-screen bg-background">
      <header
        className="relative overflow-hidden"
        style={{
          backgroundImage: `linear-gradient(135deg, oklch(0.4 0.14 295 / 0.92), oklch(0.55 0.14 295 / 0.85)), url(${heroBg})`,
          backgroundSize: "cover",
          backgroundPosition: "center",
        }}
      >
        <div className="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,oklch(0.9_0.2_120/0.3),transparent_55%)]" />
        <nav className="relative z-10 mx-auto flex max-w-6xl items-center justify-between px-5 py-5">
          <div className="flex items-center gap-2 text-primary-foreground">
            <div className="grid h-11 w-11 place-items-center overflow-hidden rounded-2xl bg-white shadow-lime-glow">
              <img src={logoAsset.url} alt="يو واو" className="h-full w-full object-cover" />
            </div>
            <span className="text-xl font-black tracking-tight">يو واو</span>
          </div>
          <a
            href="#track"
            className="rounded-full border border-white/30 bg-white/10 px-4 py-2 text-sm font-bold text-primary-foreground backdrop-blur transition hover:bg-white/20"
          >
            تتبع الآن
          </a>
        </nav>

        <div className="relative z-10 mx-auto max-w-6xl px-5 pb-16 pt-10 sm:pt-20 sm:pb-24">
          <div className="mx-auto max-w-3xl text-center">
            <span className="inline-flex items-center gap-2 rounded-full border border-white/25 bg-white/10 px-4 py-1.5 text-xs font-bold text-primary-foreground backdrop-blur">
              <Globe2 className="h-3.5 w-3.5" />
              شحن عالمي إلى اليمن
            </span>
            <h1 className="mt-6 text-4xl font-black leading-tight text-primary-foreground sm:text-6xl">
              يو واو
              <span className="mt-2 block bg-gradient-to-l from-[oklch(0.95_0.18_120)] to-[oklch(0.82_0.2_125)] bg-clip-text text-transparent">
                أطلق العنان لذوقك
              </span>
            </h1>
            <p className="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-primary-foreground/85 sm:text-lg">
              نوفر لك من جميع مواقع التسوق العالمية والخليجية 🌏🇸🇦
              <br className="hidden sm:block" />
              شحن وتوصيل لجميع مناطق اليمن 🇾🇪
            </p>

            <form
              id="track"
              onSubmit={handleSubmit}
              className="mx-auto mt-10 flex max-w-xl flex-col gap-3 rounded-3xl border border-white/20 bg-white/10 p-3 backdrop-blur-xl sm:flex-row"
            >
              <div className="flex flex-1 items-center gap-3 rounded-2xl bg-white px-4 py-3">
                <Package className="h-5 w-5 shrink-0 text-primary" />
                <input
                  value={tracking}
                  onChange={(e) => {
                    setTracking(e.target.value);
                    if (error) setError(null);
                  }}
                  placeholder="أدخل رقم الشحنة..."
                  className="w-full min-w-0 bg-transparent text-base font-medium text-foreground placeholder:text-muted-foreground focus:outline-none"
                />
              </div>
              <button
                type="submit"
                disabled={loading}
                className="flex items-center justify-center gap-2 rounded-2xl bg-gradient-lime px-6 py-3 text-base font-black text-lime-foreground shadow-lime-glow transition hover:scale-[1.02] active:scale-95 disabled:opacity-70"
              >
                {loading ? <Loader2 className="h-5 w-5 animate-spin" /> : <Search className="h-5 w-5" />}
                تتبع
              </button>
            </form>
            {error && (
              <div className="mx-auto mt-4 flex max-w-xl items-center gap-2 rounded-2xl border border-red-300/40 bg-red-500/15 px-4 py-3 text-sm font-bold text-red-50 backdrop-blur">
                <AlertCircle className="h-4 w-4 shrink-0" />
                <span>{error}</span>
              </div>
            )}
          </div>
        </div>
      </header>

      <section className="relative overflow-hidden bg-background py-8">
        <div className="pointer-events-none absolute inset-x-0 top-1/2 -z-0 h-48 -translate-y-1/2 bg-[radial-gradient(ellipse_at_center,oklch(0.85_0.18_125/0.55),transparent_60%)] blur-3xl" />
        <div className="pointer-events-none absolute inset-x-0 top-1/2 -z-0 h-40 -translate-y-1/2 bg-[radial-gradient(ellipse_at_center,oklch(0.7_0.14_295/0.4),transparent_65%)] blur-3xl" />
        <div
          className="relative z-10 flex gap-3 overflow-x-auto overflow-y-hidden px-4 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden"
          style={{ direction: "ltr", scrollSnapType: "x mandatory", WebkitOverflowScrolling: "touch" }}
        >
          {PROMO_IMAGES.map((src, i) => (
            <a
              key={i}
              href="https://wa.me/967783026377"
              target="_blank"
              rel="noopener noreferrer"
              className="block shrink-0 overflow-hidden rounded-2xl transition active:scale-95"
              style={{ scrollSnapAlign: "center" }}
              aria-label="تواصل عبر واتساب"
            >
              <img
                src={src}
                alt=""
                loading="lazy"
                className="h-40 w-auto object-cover sm:h-52"
              />
            </a>
          ))}
        </div>
      </section>


      <section className="mx-auto max-w-6xl px-5 py-16 sm:py-24">
        <div className="text-center">
          <span className="text-sm font-bold text-primary">خدماتنا</span>
          <h2 className="mt-2 text-3xl font-black text-foreground sm:text-4xl">
            اكتشف خدماتنا
          </h2>
          <p className="mx-auto mt-3 max-w-xl text-muted-foreground">
            تسوق من أشهر المواقع العالمية ونحن نتكفل بإيصال طلبك حتى باب بيتك
          </p>
        </div>

        <div className="mt-10 grid grid-cols-2 gap-4 sm:gap-6 lg:grid-cols-4">
          {SERVICES.map((s) => (
            <div
              key={s.name}
              className="group relative overflow-hidden rounded-3xl border border-border bg-card p-6 shadow-card-soft transition hover:-translate-y-1 hover:shadow-glow"
            >
              <div
                className={`grid h-14 w-14 place-items-center rounded-2xl bg-gradient-to-br ${s.grad} text-white shadow-lg`}
              >
                <ShoppingBag className="h-7 w-7" />
              </div>
              <h3 className="mt-5 text-xl font-black text-foreground">{s.name}</h3>
              <p className="mt-1 text-sm font-medium text-muted-foreground">{s.tag}</p>
              <div className="absolute -left-8 -top-8 h-24 w-24 rounded-full bg-gradient-primary opacity-0 blur-2xl transition group-hover:opacity-25" />
            </div>
          ))}
        </div>
      </section>

      <footer className="bg-gradient-hero text-primary-foreground">
        <div className="mx-auto max-w-6xl px-5 py-14">
          <div className="grid gap-10 sm:grid-cols-2">
            <div>
              <div className="flex items-center gap-2">
                <div className="grid h-11 w-11 place-items-center overflow-hidden rounded-2xl bg-white shadow-lime-glow">
                  <img src={logoAsset.url} alt="يو واو" className="h-full w-full object-cover" />
                </div>
                <span className="text-xl font-black">يو واو</span>
              </div>
              <p className="mt-3 max-w-sm text-sm text-primary-foreground/80">
                شريكك الأول للتسوق والشحن من جميع أنحاء العالم إلى اليمن.
              </p>
            </div>
            <div className="space-y-4 sm:text-left">
              <a href="tel:783026377" className="flex items-center gap-3 sm:justify-end">
                <div className="grid h-10 w-10 place-items-center rounded-full bg-white/10 backdrop-blur">
                  <Phone className="h-4 w-4" />
                </div>
                <div>
                  <p className="text-xs text-primary-foreground/70">للتواصل</p>
                  <p className="font-black tracking-wider" dir="ltr">783 026 377</p>
                </div>
              </a>
              <div className="flex items-center gap-3 sm:justify-end">
                <div className="grid h-10 w-10 place-items-center rounded-full bg-white/10 backdrop-blur">
                  <MapPin className="h-4 w-4" />
                </div>
                <div>
                  <p className="text-xs text-primary-foreground/70">الموقع</p>
                  <p className="font-black">اليمن — صنعاء</p>
                </div>
              </div>
            </div>
          </div>
          <div className="mt-10 flex flex-col items-center justify-between gap-3 border-t border-white/15 pt-5 text-center text-xs text-primary-foreground/70 sm:flex-row">
            <span>© {new Date().getFullYear()} يو واو. جميع الحقوق محفوظة.</span>
            <Link to="/auth" className="opacity-60 hover:opacity-100 hover:underline">
              لوحة التحكم
            </Link>
          </div>
        </div>
      </footer>
      <WhatsAppFab />
    </div>
  );
}
